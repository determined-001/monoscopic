{
  "name": "@monoscope/sdk",
  "version": "0.0.1",
  "private": false,
  "description": "TypeScript SDK for the Monoscope API",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@monoscope/types": "workspace:*"
  },
  "devDependencies": {}
}
